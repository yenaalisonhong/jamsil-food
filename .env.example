# === Kakao Local API (필수) ===
# https://developers.kakao.com/ → REST API 키 + 카카오맵 활성화
KAKAO_REST_API_KEY=your_kakao_rest_api_key_here

# === 프라운호퍼 한국사무소 (잠실더샵스타파크) ===
# 서울시 송파구 올림픽로 35가길 10, A동 202호
FRAUNHOFER_OFFICE_LAT=37.51692
FRAUNHOFER_OFFICE_LNG=127.10282

# === Naver Developers - Search API (평점·신규오픈 보완) ===
# https://developers.naver.com/docs/serviceapi/search/local/local.md
NAVER_CLIENT_ID=your_naver_client_id_here
NAVER_CLIENT_SECRET=your_naver_client_secret_here

# === 크롤링 (선택) ===
CRAWL_REQUEST_DELAY_SEC=1.5
CRAWL_CACHE_TTL_HOURS=24

# === 이메일 알림 (기능 C, 선택) ===
# Gmail: smtp.gmail.com + 앱 비밀번호 / M365: smtp.office365.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_RECIPIENT_EMAIL=

# 상세 설정: docs/API_GUIDE.md 참고
